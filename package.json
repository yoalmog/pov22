    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/toast": "^8.0.1",
    "@google/genai": "^2.6.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tailwindcss/vite": "^4.3.0",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
